generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TaskStatus {
  pending
  completed
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  otps      OtpCode[]
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model OtpCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([email])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model Task {
  id        String     @id @default(cuid())
  title     String
  status    TaskStatus @default(pending)
  dueDate   DateTime?
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([projectId])
}
